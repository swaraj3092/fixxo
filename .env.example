# ──────────────────────────────────────────────────────────────
# Smart Hostel Complaint System — Environment Variables Template
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to GitHub.
# ──────────────────────────────────────────────────────────────

# Twilio — WhatsApp Business API
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Supabase — PostgreSQL Database
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Resend — Email API
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key_here

# Gmail address displayed as sender name in emails
GMAIL_USER=your_email@gmail.com

# Groq API (optional — reserved for v1.1 LLM classification)
GROQ_API_KEY=your_groq_api_key_here

# Public URL of your deployed server (used inside email resolve links)
# Use your ngrok URL for local testing, Render URL for production
BASE_URL=https://your-app-name.onrender.com
